// エディタ外（ターミナル・エクスプローラー・パネル等）でも Ctrl+h/j/k/l で
// フォーカス移動できるようにする。エディタ内は VSCodeVim 側の設定が担当するため
// when: "!editorTextFocus" でエディタ以外のときだけ有効化している。
[
  { "key": "ctrl+h", "command": "workbench.action.navigateLeft", "when": "!editorTextFocus" },
  // ターミナル内では Ctrl+l をシェルに渡す（画面クリアを優先）ため terminalFocus を除外
  { "key": "ctrl+l", "command": "workbench.action.navigateRight", "when": "!editorTextFocus && !terminalFocus" },
  { "key": "ctrl+k", "command": "workbench.action.navigateUp", "when": "!editorTextFocus && !inQuickOpen" },
  { "key": "ctrl+j", "command": "workbench.action.navigateDown", "when": "!editorTextFocus && !inQuickOpen" },
  // クイックオープン（ファイル検索/コマンドパレット）の候補を上下移動: Ctrl+j / Ctrl+k
  { "key": "ctrl+j", "command": "workbench.action.quickOpenSelectNext", "when": "inQuickOpen" },
  { "key": "ctrl+k", "command": "workbench.action.quickOpenSelectPrevious", "when": "inQuickOpen" },
  // ペイン（エディタグループ）のリサイズ: Cmd+Ctrl+矢印
  // ※ macOS の Mission Control と衝突する Ctrl+矢印を避けた割り当て
  { "key": "cmd+ctrl+left", "command": "workbench.action.decreaseViewWidth" },
  { "key": "cmd+ctrl+right", "command": "workbench.action.increaseViewWidth" },
  { "key": "cmd+ctrl+up", "command": "workbench.action.increaseViewHeight" },
  { "key": "cmd+ctrl+down", "command": "workbench.action.decreaseViewHeight" }
]
